# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/drohol
# Or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/drohol?retryWrites=true&w=majority

# Admin credentials (bootstrapped on first login if no DB config exists)
ADMIN_EMAIL=admin@drohol.in
ADMIN_PASSWORD=changeme123
ADMIN_SECRET_PIN=0000

# JWT secret — change this to a long random string in production
JWT_SECRET=replace-with-a-long-random-secret-string

# Next.js public URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000
